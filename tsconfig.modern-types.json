{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2020", "DOM"],
        "declaration": true,
        "emitDeclarationOnly": true,
        "declarationMap": false,
        "noEmit": false,
        "stripInternal": false,
        "skipLibCheck": true,
        "strict": true,
        "rootDir": "./src/ts-migration",
        "outDir": "./dist/types"
    },
    "include": ["src/ts-migration/modern-types.ts", "src/ts-migration/leafer/**/*.ts"],
    "exclude": ["node_modules", "dist", "coverage", "playwright-report", "test-results"]
}
