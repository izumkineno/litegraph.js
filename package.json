{
    "name": "litegraph.js",
    "version": "0.7.14",
    "description": "A graph node editor similar to PD or UDK Blueprints. It works in an HTML5 Canvas and allows to export graphs to be included in applications.",
    "main": "dist/litegraph.core.js",
    "types": "src/litegraph.d.ts",
    "exports": {
        ".": "./dist/litegraph.core.js",
        "./core": "./dist/litegraph.core.js",
        "./basic": "./dist/litegraph.basic.js",
        "./extended": "./dist/litegraph.extended.js",
        "./css": "./dist/css/litegraph.css",
        "./package.json": "./package.json"
    },
    "directories": {
        "doc": "doc"
    },
    "private": false,
    "packageManager": "bun@1.2.21",
    "scripts": {
        "build": "bun run build:dist",
        "build:dist": "node scripts/build-dist.mjs",
        "test": "bunx jest",
        "test:allVersions": "./utils/test.sh",
        "prettier": "bunx prettier --write src/**/*.* css/**/*.* editor/**/*.* tests/**/*.* guides/**/*.* scripts/**/*.*",
        "lint": "bunx eslint src tests scripts",
        "lint:fix": "bunx eslint --fix src tests scripts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jagenjo/litegraph.js.git"
    },
    "author": "jagenjo",
    "license": "MIT",
    "files": [
        "dist",
        "src/litegraph.d.ts"
    ],
    "devDependencies": {
        "vite": "^7.3.1",
        "eslint": "^10.0.2",
        "@eslint/js": "^10.0.1",
        "eslint-plugin-jest": "^29.15.0",
        "jest": "^30.2.0",
        "@types/jest": "^30.0.0"
    }
}
