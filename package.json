{
    "name": "litegraph.js",
    "version": "0.7.14",
    "description": "A graph node editor similar to PD or UDK Blueprints. It works in an HTML5 Canvas and allows to export graphs to be included in applications.",
    "main": "dist/litegraph.core.js",
    "types": "src/litegraph.d.ts",
    "exports": {
        ".": "./dist/litegraph.core.js",
        "./core": "./dist/litegraph.core.js",
        "./basic": "./dist/litegraph.basic.js",
        "./extended": "./dist/litegraph.extended.js",
        "./modern-types": {
            "types": "./dist/types/modern-types.d.ts",
            "default": "./dist/modern-types.js"
        },
        "./css": "./dist/css/litegraph.css",
        "./package.json": "./package.json"
    },
    "directories": {
        "doc": "doc"
    },
    "private": false,
    "packageManager": "bun@1.2.21",
    "scripts": {
        "dev:editor": "vite",
        "build": "bun run build:dist",
        "build:dist": "node scripts/build-dist.mjs",
        "build:ts-migration": "node scripts/build-ts-migration.mjs",
        "build:modern-types": "node scripts/build-modern-types.mjs",
        "build:all": "bun run build:dist && bun run build:ts-migration && bun run build:modern-types",
        "typecheck": "bunx tsc -p tsconfig.typecheck.json",
        "test": "bunx jest",
        "test:e2e": "npx playwright test",
        "test:e2e:full": "npx playwright test",
        "test:e2e:core": "npx playwright test --grep @core",
        "test:e2e:family": "npx playwright test --grep @family",
        "test:e2e:ui": "npx playwright test --ui",
        "test:e2e:headed": "npx playwright test --headed",
        "test:allVersions": "./utils/test.sh",
        "prettier": "bunx prettier --write src/**/*.* css/**/*.* editor/**/*.* tests/**/*.* guides/**/*.* scripts/**/*.*",
        "lint": "bunx eslint src tests scripts",
        "lint:fix": "bunx eslint --fix src tests scripts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jagenjo/litegraph.js.git"
    },
    "author": "jagenjo",
    "license": "MIT",
    "files": [
        "dist",
        "src/litegraph.d.ts"
    ],
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.55.0",
        "@types/jest": "^30.0.0",
        "eslint": "^10.0.3",
        "eslint-plugin-jest": "^29.15.0",
        "jest": "^30.2.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    },
    "dependencies": {
        "@leafer-in/arrow": "^2.0.2",
        "@leafer-in/flow": "^2.0.2",
        "@leafer-in/resize": "^2.0.2",
        "@leafer-in/state": "2.0.2",
        "@leafer-in/view": "^2.0.2",
        "@leafer-in/viewport": "2.0.2",
        "leafer-ui": "2.0.2"
    }
}
